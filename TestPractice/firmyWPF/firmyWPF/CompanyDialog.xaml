<Window x:Class="firmyWPF.CompanyDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:firmyWPF"
        mc:Ignorable="d"
        Title="CompanyDialog" Height="450" Width="800">
    <Grid>
        <StackPanel Margin="20">
            <TextBlock Text="Nazev firmy"/>
            <TextBox x:Name="NazevTextBox"/>
            <TextBlock Text="DIC:"/>
            <TextBox x:Name="DICTextBox"/>
            <TextBlock Text="Obec:"/>
            <TextBox x:Name="ObecTextBox"/>
            <TextBlock Text="Poznamka"/>
            <TextBox x:Name="PoznamkaTextBox"/>
            <Button Click="CompanyPageButtonClick" Content="Ulozit"/>
        </StackPanel>
    </Grid>
</Window>
