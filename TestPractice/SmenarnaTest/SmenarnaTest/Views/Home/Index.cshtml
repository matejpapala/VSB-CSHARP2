@model SmenarnaTest.Models.ExchangeFormModel

@{
    ViewData["Title"] = "Smenarna - index";
}

<div class="text-center">
    <h1 class="display-4">Kalkulacka men</h1>
    <p>Vyplnte formular</p>
</div>

<form asp-action="ZpracujSmenu" method="post" style="max-width: 400px; margin: 0 auto">
    <div class="form-group mt-3">
        <label asp-for="Name">Name:</label>
        <input asp-for="Name"class="form-control"/>
        <span asp-validation-for="Name" class="text-bg-danger"></span>
    </div>
    <div class="form-group mt-3">
        <label asp-for="Email">Email:</label>
        <input asp-for="Email" class="form-control"/>
        <span asp-validation-for="Email" class="text-bg-danger"></span>
    </div>
    <div class="form-group mt-3">
        <label asp-for="Currency">Currency</label>
        <select asp-for="Currency">
            @if (ViewBag.Meny != null)
                    {
                        foreach(var mena in ViewBag.Meny)
                        {
                            <option value="@mena">@mena</option>
                        }
                    }
                </select>
         <span asp-validation-for="Currency" class="text-bg-danger"></span>
    </div>
    <div class="form-group mt-3">
        <label asp-for="Value">Value:</label>
        <input asp-for="Value" type="number" class="form-control"/>
        <span asp-validation-for="Value"></span>
    </div>
    <button type="submit" class="btn btn-primary mt-4 w-100">Calculate and save</button>
</form>